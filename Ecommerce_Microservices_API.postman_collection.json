    },
    {
      "name": "Product Service",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/actuator/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products"]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/products/{{productId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop\",\n  \"description\": \"Gaming Laptop\",\n  \"price\": 1200.00,\n  \"category\": \"Electronics\",\n  \"active\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8082/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products"]
            }
          }
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/actuator/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8083/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["orders"]
            }
          }
        }
      ]
    },
    {
      "name": "Inventory Service",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8084/actuator/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Get Inventory",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8084/inventory/{{productId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["inventory", "{{productId}}"]
            }
          }
        },
        {
          "name": "Update Stock",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "http://localhost:8084/inventory/{{productId}}?stock=5",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["inventory", "{{productId}}"],
              "query": [
                {
                  "key": "stock",
                  "value": "5"
                }
              ]
            }
          }
        }
      ]
    }
