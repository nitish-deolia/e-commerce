              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["auth", "login"]
