{
  "info": {
    "name": "E-commerce Microservices API",
    "description": "API collection for the e-commerce platform microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"testuser\",\"email\":\"test@example.com\",\"password\":\"password123\"}"
            },
            "url": {
              "raw": "http://localhost:8081/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"testuser\",\"password\":\"password123\"}"
            },
            "url": {
              "raw": "http://localhost:8081/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Product Service",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products"]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Laptop\",\"description\":\"Gaming Laptop\",\"price\":1200.00,\"category\":\"Electronics\",\"stock\":10}"
            },
            "url": {
              "raw": "http://localhost:8082/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products"]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/products/{{productId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"userId\":1,\"items\":[{\"productId\":1,\"quantity\":2}],\"total\":2400.00}"
            },
            "url": {
              "raw": "http://localhost:8083/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/orders/{{orderId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["orders", "{{orderId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Inventory Service",
      "item": [
        {
          "name": "Get Inventory",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8084/inventory",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["inventory"]
            }
          }
        },
        {
          "name": "Update Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"productId\":1,\"stock\":8}"
            },
            "url": {
              "raw": "http://localhost:8084/inventory",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["inventory"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "orderId",
      "value": "1"
    }
  ]
}